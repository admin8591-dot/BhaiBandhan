/* =====================================================================
   BhaiBandhan — Instant Load Cache (cache.js)
   ---------------------------------------------------------------------
   HOW TO USE:
   1. Upload this file to your GitHub repo (same repo as your site).
   2. In your index.html, add this line — but IMPORTANT: it must go
      BEFORE your main <script> block (the big one with all your
      product/cart code), not after it. Easiest spot: right after
      your opening <body> tag, or anywhere in <head>.

        <script src="cache.js"></script>

   3. Done. No other file needs to change.

   HOW IT WORKS:
   - First visit: loads normally (a few seconds), then saves the
     response in the browser's storage.
   - Every visit after that: shows the saved (slightly older) data
     INSTANTLY — no more 4-7 sec loading wait — while quietly
     fetching fresh data in the background for the NEXT visit.
   - So visitors always see something instantly; data is at most
     one visit "behind," which refreshes itself automatically.

   To force-clear the cache (e.g. right after you add lots of new
   products in admin), just tell visitors to hard-refresh once, or
   you can open the browser console on your own phone and run:
     localStorage.clear()
   ===================================================================== */

(function(){
  const originalFetch = window.fetch;

  window.fetch = function(url, options){
    const isGetAll = typeof url === 'string' && url.includes('action=getAll');

    if(!isGetAll){
      return originalFetch(url, options);
    }

    const cacheKey = 'bb_cache_' + url;
    const cached = localStorage.getItem(cacheKey);

    if(cached){
      // Serve the cached response immediately (instant load)
      // and silently refresh the cache in the background for next time.
      originalFetch(url, options)
        .then(res => res.clone().text())
        .then(text => localStorage.setItem(cacheKey, text))
        .catch(()=>{ /* ignore background refresh errors */ });

      return Promise.resolve(new Response(cached, {
        status: 200,
        headers: { 'Content-Type': 'application/json' }
      }));
    }

    // No cache yet (first-ever visit) — fetch normally and save it
    return originalFetch(url, options).then(res => {
      res.clone().text().then(text => localStorage.setItem(cacheKey, text)).catch(()=>{});
      return res;
    });
  };
})();

